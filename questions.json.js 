// Helper function to shuffle array
function shuffleArray(array) {
    for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
    }
    return array;
}

// Get shuffled questions for a course
function getQuestions(course, count = 20) {
    console.log(`Getting questions for ${course}, count: ${count}`);
    const allQuestions = QUESTION_BANK[course] || QUESTION_BANK["MTH101"];
    const shuffled = shuffleArray([...allQuestions]);
    const result = shuffled.slice(0, Math.min(count, shuffled.length));
    console.log(`Returning ${result.length} questions`);
    return result;
}

// Get random questions from all subjects
function getRandomQuestions(count = 20) {
    let allQuestions = [];
    for (let course in QUESTION_BANK) {
        allQuestions = allQuestions.concat(QUESTION_BANK[course]);
    }
    const shuffled = shuffleArray([...allQuestions]);
    return shuffled.slice(0, Math.min(count, shuffled.length));
}

